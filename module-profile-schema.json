{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Modul-Profil für den Student AI Agent",
  "type": "object",
  "required": ["name", "slug"],
  "properties": {
    "name":             { "type": "string", "example": "Algorithmen & Datenstrukturen" },
    "slug":             { "type": "string", "example": "algorithmen-datenstrukturen" },
    "aliases":          { "type": "array", "items": { "type": "string" }, "example": ["AlgoDat", "AuD"] },
    "schwerpunkte":     { "type": "array", "items": { "type": "string" } },
    "pruefungsrelevant":{ "type": "array", "items": { "type": "string" } },
    "stil":             { "type": "string", "enum": ["mathe", "informatik", "geistes", "bwl", "mixed"] },
    "prompt_hint":      { "type": "string", "example": "Immer Intuition vor formaler Definition. O-Notation bei jedem Algorithmus." },
    "extra":            { "type": "string", "example": "Prof. nutzt nur Induktionsbeweise. Sehr formale Sprache." },
    "exam_profile":     { "type": "string", "description": "Pfad zur Prüfungsanalyse-Datei", "example": "modules/algorithmen-datenstrukturen-exam-profile.md" },
    "history":          { "type": "string", "description": "Pfad zur Vorlesungs-History", "example": "modules/algorithmen-datenstrukturen-history.md" },
    "created_at":       { "type": "string", "format": "date" },
    "updated_at":       { "type": "string", "format": "date" }
  }
}
